{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Xiaohongshu Content Employee Delivery",
  "type": "object",
  "required": [
    "content_digest",
    "project",
    "evidence",
    "topics",
    "titles",
    "post",
    "tags",
    "cover",
    "carousel",
    "images"
  ],
  "properties": {
    "content_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "project": {
      "type": "object"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "titles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {"type": "string"},
          "recommended": {"type": "boolean"}
        }
      }
    },
    "post": {
      "type": "object",
      "properties": {
        "body": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "cover": {
      "type": "object"
    },
    "carousel": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "usage": {"type": "string"},
          "source": {"type": "string"},
          "source_type": {
            "type": "string",
            "enum": ["provided", "ai_generated", "derived"]
          },
          "provider": {"type": "string"},
          "model": {"type": "string"},
          "width": {"type": "integer"},
          "height": {"type": "integer"}
        }
      }
    }
  }
}
