{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Xiaohongshu Content Employee Workflow State",
  "type": "object",
  "required": [
    "workflow_id",
    "state_version",
    "updated_at",
    "stage",
    "status",
    "artifacts",
    "blockers",
    "confirmations",
    "checkpoint",
    "transition_log",
    "next_action"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "state_version": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stage": {
      "type": "string",
      "enum": [
        "prepare",
        "evidence",
        "compose",
        "produce",
        "deliver",
        "completed"
      ]
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "first_task_input": {
          "type": [
            "object",
            "null"
          ]
        },
        "material_record": {
          "type": [
            "object",
            "null"
          ]
        },
        "evidence_package": {
          "type": [
            "object",
            "null"
          ]
        },
        "complete_content_package": {
          "type": [
            "object",
            "null"
          ]
        },
        "content_digest": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "image_runtime": {
          "$ref": "#/$defs/image_runtime"
        },
        "generated_images": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "object"
          }
        },
        "delivery_json": {
          "type": [
            "string",
            "null"
          ]
        },
        "delivery_html": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "reason",
          "resolution_needed"
        ],
        "properties": {
          "stage": {
            "$ref": "#/$defs/stage"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "resolution_needed": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "blocking"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "confirmations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "stage",
          "question",
          "status"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "image_mode_selection",
              "provider_model_selection",
              "generation_batch_approval",
              "critical_fact_resolution",
              "requested_topic_selection",
              "knowledge_candidate_review"
            ]
          },
          "stage": {
            "$ref": "#/$defs/stage"
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "rejected"
            ]
          },
          "answer": {
            "type": [
              "string",
              "null"
            ]
          },
          "digest": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "checkpoint": {
      "type": "object",
      "required": [
        "name",
        "sequence",
        "last_valid_stage",
        "resume_from",
        "artifact_refs"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "facts_locked",
            "content_visual_ready",
            "image_final_results",
            "html_delivered"
          ]
        },
        "sequence": {
          "type": "integer",
          "minimum": 0
        },
        "last_valid_stage": {
          "$ref": "#/$defs/stage"
        },
        "resume_from": {
          "$ref": "#/$defs/stage"
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "transition_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sequence",
          "from",
          "to",
          "status",
          "reason"
        ],
        "properties": {
          "sequence": {
            "type": "integer",
            "minimum": 0
          },
          "from": {
            "$ref": "#/$defs/stage"
          },
          "to": {
            "$ref": "#/$defs/stage"
          },
          "status": {
            "$ref": "#/$defs/status"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "from_status": {
            "$ref": "#/$defs/status"
          },
          "to_status": {
            "$ref": "#/$defs/status"
          }
        },
        "additionalProperties": true
      }
    },
    "next_action": {
      "type": "object",
      "required": [
        "owner",
        "summary"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "enum": [
            "agent",
            "user"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "learning": {
      "$ref": "#/$defs/learning"
    }
  },
  "oneOf": [
    {
      "properties": {
        "stage": {
          "const": "prepare"
        },
        "status": {
          "enum": [
            "IN_PROGRESS",
            "WAITING_CONFIRMATION",
            "BLOCKED"
          ]
        }
      }
    },
    {
      "properties": {
        "stage": {
          "const": "evidence"
        },
        "status": {
          "enum": [
            "IN_PROGRESS",
            "BLOCKED"
          ]
        }
      }
    },
    {
      "properties": {
        "stage": {
          "const": "compose"
        },
        "status": {
          "enum": [
            "IN_PROGRESS",
            "WAITING_CONFIRMATION",
            "BLOCKED"
          ]
        }
      }
    },
    {
      "properties": {
        "stage": {
          "const": "produce"
        },
        "status": {
          "enum": [
            "IN_PROGRESS",
            "WAITING_CONFIRMATION",
            "BLOCKED"
          ]
        }
      }
    },
    {
      "properties": {
        "stage": {
          "const": "deliver"
        },
        "status": {
          "enum": [
            "IN_PROGRESS",
            "BLOCKED"
          ]
        }
      }
    },
    {
      "properties": {
        "stage": {
          "const": "completed"
        },
        "status": {
          "enum": [
            "COMPLETED"
          ]
        }
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "stage": {
      "type": "string",
      "enum": [
        "prepare",
        "evidence",
        "compose",
        "produce",
        "deliver",
        "completed"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "IN_PROGRESS",
        "WAITING_CONFIRMATION",
        "BLOCKED",
        "COMPLETED"
      ]
    },
    "image_runtime": {
      "type": "object",
      "required": [
        "mode",
        "setup_source",
        "provider",
        "model",
        "size",
        "quality",
        "config_status",
        "preflight_status",
        "preflight_checked_at",
        "generation_status"
      ],
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "existing_only",
            "ai_assist",
            null
          ]
        },
        "setup_source": {
          "type": "string",
          "enum": [
            "first_run",
            "saved_default",
            "task_override"
          ]
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "size": {
          "type": [
            "string",
            "null"
          ]
        },
        "quality": {
          "type": [
            "string",
            "null"
          ]
        },
        "config_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "configured",
            "not-configured",
            "not-required",
            null
          ]
        },
        "preflight_status": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "passed",
            "failed",
            "not-required",
            null
          ]
        },
        "preflight_checked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "generation_status": {
          "type": "string",
          "enum": [
            "not_requested",
            "waiting_approval",
            "ready",
            "generating",
            "complete",
            "blocked",
            "uncertain"
          ]
        },
        "batch_digest": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{64}$"
        },
        "generated_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "learning": {
      "type": "object",
      "required": [
        "enabled",
        "learning_notice_shown",
        "storage_reference",
        "applied_preference_ids",
        "applied_knowledge_ids",
        "pending_candidate_ids"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "learning_notice_shown": {
          "type": "boolean"
        },
        "storage_reference": {
          "const": "xhs-user-data://knowledge"
        },
        "applied_preference_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "applied_knowledge_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pending_candidate_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
